{
  "name": "s3-on-ftp",
  "version": "1.0.0",
  "description": "S3-compatible API proxy for FTP, SFTP, and SCP backends",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "check": "tsc --noEmit",
    "test": "vitest run --reporter=verbose"
  },
  "keywords": ["typescript", "express", "s3", "ftp", "sftp", "proxy"],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "basic-ftp": "^5.0.5",
    "cors": "^2.8.5",
    "express": "^4.18.2",
    "ssh2": "^1.15.0",
    "xmlbuilder2": "^4.0.3"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^20.10.0",
    "@types/ssh2": "^1.11.19",
    "@vitest/coverage-v8": "^4.0.18",
    "tsx": "^4.6.0",
    "typescript": "^5.3.0",
    "vitest": "^4.0.18"
  }
}
